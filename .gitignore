*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# Testing & coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Type checking
.mypy_cache/

# IDE
.vscode/
.idea/
*.swp

# System files
.DS_Store
Thumbs.db

# Environment variables
.env

# MLflow / experiment tracking
mlruns/
mlartifacts/