# Large / irrelevant directories (per project guidance)
data/
notebooks/
venv/
mlruns/
.git/
__pycache__/

# Common Python / tooling noise
**/__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/
*.egg-info/
.ipynb_checkpoints/

